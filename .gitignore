# Ignore everything
/*

# Allow specific ones
!/backend/
!/frontend/
!/README.md
!/.gitignore

# --- Backend Specifics ---
/backend/node_modules/
/backend/log/
/backend/tmp/
/backend/storage/
/backend/*.log
/backend/db/*.sqlite3
/backend/db/*.sqlite3-journal
/backend/public/assets/
/backend/public/packs/
/backend/public/packs-test/
/backend/.bundle/
/backend/vendor/bundle/
/backend/.env*

# --- Frontend Specifics ---
/frontend/node_modules/
/frontend/.next/
/frontend/out/
/frontend/build/
/frontend/dist/
/frontend/*.log
/frontend/.env*
/frontend/.vercel/
/frontend/tsconfig.tsbuildinfo
